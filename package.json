{
  "name": "@irailmetro/rmt-cli",
  "version": "0.2.1",
  "description": "CLI for scaffolding iPLAT4J Maven projects",
  "license": "UNLICENSED",
  "type": "commonjs",
  "bin": {
    "rmt": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test:e2e": "node tests/create.e2e.cjs",
    "ci": "npm run check && npm run build && npm run test:e2e",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.17.57",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=16.14"
  }
}
